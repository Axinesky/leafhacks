## API proxy settings
API_PORT=8787

## Gemini (text feedback always uses Gemini; images default to the free provider below)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

## Image generation provider. "pollinations" is free and needs no key.
## Set to "gemini" to use Gemini image generation instead (needs credits).
IMAGE_PROVIDER=pollinations

## ElevenLabs
ELEVENLABS_API_KEY=your_elevenlabs_api_key
## eleven_multilingual_v2 = best quality (1 credit per character).
## eleven_flash_v2_5 = half the credit cost and faster, slightly lower quality.
ELEVENLABS_MODEL=eleven_multilingual_v2
## Used when a requested voice does not exist on the account (legacy voice IDs
## have been retired by ElevenLabs). Defaults to George from the current lineup.
ELEVENLABS_FALLBACK_VOICE=JBFqnCBsd6RMkjVDRZzb

## Frontend build-time API origin for deployed environments.
## Leave unset in local development so Vite proxy handles /api.
VITE_API_BASE_URL=
